# Anthropic — enables the LLM proposer + WebSearchProvider. Absent => deterministic proposer.
ANTHROPIC_API_KEY=

# Rapidflare component API — enables RapidflareProvider. Absent => provider marks itself unavailable.
RAPIDFLARE_API_BASE=https://api.rapidflare.ai
RAPIDFLARE_API_KEY=

# Durable Store. Absent => file-based Store under ./data (local dev). Present => Postgres Store.
# Supabase on Vercel: use the TRANSACTION POOLER url (port 6543), not the direct 5432 one.
#   e.g. postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres
# SSL is auto-enabled for non-localhost hosts. Tune per-instance pool size if needed.
POSTGRES_URL=
# PG_POOL_MAX=1   # serverless default; raise for a persistent host

# Default model when none chosen at runtime.
DEFAULT_MODEL=claude-opus-4-8
